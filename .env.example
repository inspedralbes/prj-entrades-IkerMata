# Copiar: cp .env.example .env
#
# IMPORTANT: solo UNA vez "http://" en cada línea. Sustituye TU_IP por tu IP o dominio
# (solo host, sin http://). Si pones http:// dos veces queda http://http://... y falla.
#
# Correcto:
#   NUXT_PUBLIC_API_BASE=http://203.0.113.50:8001/api
#   NUXT_PUBLIC_GATEWAY_URL=http://203.0.113.50:3003
#
# Incorrecto:
#   NUXT_PUBLIC_API_BASE=http://http://203.0.113.50:8001/api

NUXT_PUBLIC_API_BASE=http://TU_IP:8001/api
NUXT_PUBLIC_GATEWAY_URL=http://TU_IP:3003
