# Copiar a .env en esta misma carpeta:  cp .env.example .env
# Sustituir TU_IP_O_DOMINIO por la IP pública o el dominio con el que abres el front en el navegador.
# Ejemplo con IP:   http://203.0.113.50:8001/api
# Ejemplo con DNS: http://cinema.ejemplo.com:8001/api

NUXT_PUBLIC_API_BASE=http://TU_IP_O_DOMINIO:8001/api
NUXT_PUBLIC_GATEWAY_URL=http://TU_IP_O_DOMINIO:3003
