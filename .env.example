# Copiar: cp .env.example .env
#
# IMPORTANT: solo UNA vez "http://" en cada línea. Si pones http:// dos veces queda http://http://... y falla.
#
# --- Opción A: mismo dominio HTTPS (recomendado si el front se sirve en https://tu-dominio/...) ---
# Nginx debe hacer proxy de /api hacia Laravel (puerto 8001) y /socket.io hacia el gateway (3003).
# Ver deploy/reverse-proxy.example.conf
#
#   NUXT_PUBLIC_API_BASE=/api
#   NUXT_PUBLIC_GATEWAY_URL=auto
#
# --- Opción B: IP o dominio HTTP explícito (solo si entras al front también por HTTP, misma política) ---
# Si el front está en https:// y aquí pones http://IP:8001 el navegador BLOQUEA las peticiones (mixed content).
#
#   NUXT_PUBLIC_API_BASE=http://TU_IP:8001/api
#   NUXT_PUBLIC_GATEWAY_URL=http://TU_IP:3003

NUXT_PUBLIC_API_BASE=http://TU_IP:8001/api
NUXT_PUBLIC_GATEWAY_URL=http://TU_IP:3003
