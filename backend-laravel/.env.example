APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Domini del frontend Nuxt (Sanctum SPA / cookies; opcional si només uses Bearer)
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3002,127.0.0.1,127.0.0.1:3002

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Docker Compose: Postgres (host `db` dins la xarxa Docker). NO usar sqlite :memory: per a l'API — no hi ha taules.
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret

# Sense Docker (Postgres al port mapejat, p. ex. 5433):
# DB_HOST=127.0.0.1
# DB_PORT=5433

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Amb Docker Compose usar host `redis` i client `predis` (sense extensió phpredis al contenidor).
# Local sense Docker: REDIS_HOST=127.0.0.1
REDIS_CLIENT=predis
# Docker: REDIS_HOST=redis | Local: 127.0.0.1
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
# Empty = no prefix on PUBLISH channels (must match gateway Node / ioredis subscribe). Default Laravel prefix breaks pub/sub.
REDIS_PREFIX=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Venda d'entrades (enunciat: límit N seients, reserva 3–5 min — per defecte 8 i 5 min)
MAX_SEIENTS_RESERVA_SESSIO=8
RESERVA_TEMPORAL_MINUTS=5

VITE_APP_NAME="${APP_NAME}"
